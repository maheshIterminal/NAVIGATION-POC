{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://navigation-poc-production.up.railway.app",
        "EXPO_PUBLIC_WS_URL": "wss://navigation-poc-production.up.railway.app/ws/driver"
      }
    },
    "production": {
      "autoIncrement": true,
      "distribution": "store",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://navigation-poc-production.up.railway.app",
        "EXPO_PUBLIC_WS_URL": "wss://navigation-poc-production.up.railway.app/ws/driver"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {}
    }
  }
}
