{
  "name": "navigation-poc",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@expo/metro-runtime": "~56.0.14",
    "@googlemaps/react-native-navigation-sdk": "^0.16.1",
    "babel-preset-expo": "~56.0.0",
    "expo": "~56.0.9",
    "expo-build-properties": "~56.0.17",
    "expo-constants": "~56.0.17",
    "expo-haptics": "~56.0.3",
    "expo-image-picker": "~56.0.18",
    "expo-linking": "~56.0.13",
    "expo-location": "~56.0.16",
    "expo-router": "~56.2.9",
    "expo-secure-store": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-google-places-textinput": "^0.9.2",
    "react-native-maps": "1.27.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "TOOLCHAINS=com.apple.dt.toolchain.XcodeDefault expo run:ios",
    "prebuild": "expo prebuild",
    "verify": "tsc --noEmit && npx expo-doctor",
    "web": "expo start --web",
    "mock-server": "npm run start --prefix mock-server",
    "dev": "npm run mock-server & npm run start"
  },
  "private": true,
  "expo": {
    "autolinking": {
      "ios": {
        "exclude": ["@expo/ui", "expo-ui"]
      }
    }
  }
